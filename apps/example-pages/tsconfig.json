{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "noEmit": true,
    "rootDir": "./",
    "paths": {
      "@cl3/core": [
        "../../packages/core/dist/index.d.ts"
      ],
      "@cl3/source-filesystem": [
        "../../packages/source-filesystem/dist/index.d.ts"
      ]
    },
    "allowJs": true,
    "incremental": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": [
    "pages",
    "cl3.config.ts",
    "next-env.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
